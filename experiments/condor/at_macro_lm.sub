# HTCondor submit file for AT macro_economics + LM + KL-SFT beta sweep.
#
# Submit with:  condor_submit_bid <BID> experiments/condor/at_macro_lm.sub
#
# Each row in experiments/condor/configs_macro_betas.txt fires one job with
# (tag, style, beta). Mirrors at_covid_lm.sub but dispatches to
# run_one_macro.sh / scripts/run_macro_lm.py and uses the macro YAML.

universe          = vanilla
executable        = /home/gsmithline/perfsim/experiments/condor/run_one_macro.sh
arguments         = $(tag) $(style) $(beta)

# ---- resources ----
# 7B trainee + 7B KL reference + activations + Adam state for LoRA fit in
# ~30 GB VRAM. Macro_economics with 100 agents is much smaller than covid's
# 37k agents, so generation is fast — main memory pressure is just the two
# LM copies. 128G host RAM matches what worked for covid + KL.
request_cpus      = 4
request_memory    = 128G
request_disk      = 40G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 40000)

# ---- env / io ----
getenv            = False
environment       = "REPO=/home/gsmithline/perfsim CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key WANDB_PROJECT=perfsim-at-macro-lm N_ROUNDS=5 K_STEPS=3 BASE_MODEL=Qwen/Qwen2.5-7B-Instruct SFT_MAX_STEPS=500 SFT_FULL_EPOCH=0 SFT_BATCH_SIZE=16 GEN_BATCH_SIZE=32 MAX_NEW_TOKENS=16 MACRO_YAML=config_100_agents.yaml N_AGENTS=2712360 GROUP_PROMPTING=1 SFT_SANITY=1 LORA_R=32 USE_LORA=1 SFT_LR=1e-5 WANDB_RUN_SUFFIX=_qwen7b_lora32 CALIBRATED_UAC=/home/gsmithline/perfsim/runs/calibration_macro/recovery_lr0p05/calibrated_UAC.pt"

output            = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).out
error             = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).err
log               = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).log

# ---- email + retries ----
notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu
max_retries       = 2
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta from experiments/condor/configs_macro_betas.txt
