# HTCondor: Pokec FJ + LM deployment-schedule factorial.
#
# Same FJ + LM loop as the beta sweep, but fixes the predictor (sft, beta=0) and
# varies the deployment schedule / data aggregation:
#   1. deploy every round   -> replace, accumulate
#   2. deploy every K=3      -> replace, accumulate, deployed_into, not_deployed_into
# One condor job + one W&B run per cell (distinguish by config.deploy_every and
# config.data_regime). 7B LoRA r=512 to match the beta sweep.
#
# Submit: condor_submit_bid <BID> experiments/condor/at_pokec_fj_schedules.sub

universe          = vanilla
executable        = /home/gsmithline/perfsim/experiments/condor/run_one_pokec_fj.sh
arguments         = $(tag) $(style) $(beta) $(seed) $(deploy_every) $(regime)

request_cpus      = 4
request_memory    = 128G
request_disk      = 40G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 80000)

getenv            = False
environment       = "REPO=/home/gsmithline/perfsim CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key WANDB_PROJECT=perfsim-pokec-fj-lm N_ROUNDS=30 EPOCH_SIZE=20 BASE_MODEL=Qwen/Qwen2.5-7B-Instruct SFT_EPOCHS=1 SFT_BATCH_SIZE=4 GEN_BATCH_SIZE=32 LORA_R=512 USE_LORA=1 SFT_LR=5e-5 N_LABELED=1730 HIST_BINS=50 LOG_PERPLEXITY=1 N_PERPLEXITY=64 WANDB_RUN_SUFFIX=_qwen7b_lora512"

output            = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).out
error             = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).err
log               = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).log

notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu
max_retries       = 2
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta, seed, deploy_every, regime from experiments/condor/configs_pokec_fj_schedules.txt
