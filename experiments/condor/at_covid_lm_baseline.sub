# HTCondor submit file for the frozen-LM reference baseline.
#
# Deploys base Qwen-7B-Instruct with NO SFT and NO KL anchor for the full
# n_rounds. Measures the population trajectory under the pretrained prior
# alone. This is the "beta=infinity" reference attractor that the regular
# at_covid_lm.sub sweep's KL-anchored policies are pulled toward.
#
# Submit with:  condor_submit_bid <BID> experiments/condor/at_covid_lm_baseline.sub

universe          = vanilla
executable        = /home/gsmithline/perfsim/experiments/condor/run_one.sh
arguments         = $(tag) $(style) $(beta)

# ---- resources ----
# Only the trainee model is loaded (no KL reference), so memory is roughly
# half what the sft_kl runs need. 64G host RAM is comfortable.
request_cpus      = 4
request_memory    = 64G
request_disk      = 40G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 40000)

# ---- env / io ----
getenv            = False
environment       = "REPO=/home/gsmithline/perfsim CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key WANDB_PROJECT=perfsim-at-covid-lm N_ROUNDS=5 K_STEPS=3 SEED_FRAC=0.20 BASE_MODEL=Qwen/Qwen2.5-7B-Instruct SFT_MAX_STEPS=20 SFT_FULL_EPOCH=0 SFT_BATCH_SIZE=16 GEN_BATCH_SIZE=32 TARGET_KIND=exposure_aware SFT_SANITY=0 LORA_R=32 USE_LORA=1 SFT_LR=1e-5 WANDB_RUN_SUFFIX=_qwen7b_frozen_baseline"

output            = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).out
error             = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).err
log               = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).log

# ---- email + retries ----
notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu
max_retries       = 2
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta from experiments/condor/configs_baseline.txt
