# HTCondor submit file for AT covid + LM + KL-SFT beta sweep.
#
# Matches local MLP beta sweep diagnostic (37k agents, 12 rounds, K=3,
# default R2, exposure-aware target). Each row in configs_betas.txt fires
# one job: 3 jobs at beta = 0, 1, 10.
#
# Submit with: condor_submit_bid <BID> experiments/condor/at_covid_lm.sub

universe          = vanilla
executable        = /home/gsmithline/perfsim/experiments/condor/run_one.sh
arguments         = $(tag) $(style) $(beta)

request_cpus      = 4
request_memory    = 64G
request_disk      = 40G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 40000)

getenv            = False
environment       = "REPO=/home/gsmithline/perfsim CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key WANDB_PROJECT=perfsim-at-covid-lm N_ROUNDS=12 K_STEPS=3 SEED_FRAC=0.05 BASE_MODEL=Qwen/Qwen2.5-7B-Instruct SFT_MAX_STEPS=500 SFT_FULL_EPOCH=0 SFT_BATCH_SIZE=16 GEN_BATCH_SIZE=32 TARGET_KIND=exposure_aware GROUP_PROMPTING=1 SFT_SANITY=1 LORA_R=32 USE_LORA=1 SFT_LR=1e-5 WANDB_RUN_SUFFIX=_qwen7b_lora32"

output            = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).out
error             = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).err
log               = /home/gsmithline/perfsim/experiments/condor/logs/$(tag).log

notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu
max_retries       = 2
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta from experiments/condor/configs_betas.txt
