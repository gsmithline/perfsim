universe = vanilla
executable = /home/gsmithline/perfsim/condor/run_one.sh
arguments = $(tag) $(style) $(beta)

environment = "SEED_FRAC=$(frac) CALIBRATED_R2=$(r2) K_STEPS=21 N_ROUNDS=10 BASE_MODEL=Qwen/Qwen2.5-7B-Instruct SFT_BATCH_SIZE=4 WANDB_PROJECT=perfsim-covid-calibrated TARGET_KIND=exposure_aware LORA_R=32 USE_LORA=1 SFT_LR=1e-5 SFT_MAX_STEPS=50 SFT_SANITY=1"

output = condor/logs/$(tag).out
error  = condor/logs/$(tag).err
log    = condor/logs/$(tag).log

request_cpus = 4
request_memory = 64G
request_disk = 10G
request_gpus = 1

requirements = (OpSys == "LINUX") && (TARGET.CUDAGlobalMemoryMb >= 40000)

should_transfer_files = NO

notify_user = gsmithline@gmail.com
notification = Complete

queue tag, style, beta, frac, r2 from condor/configs_omicron_sweep.txt
