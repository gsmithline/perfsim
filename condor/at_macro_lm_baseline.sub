# HTCondor submit file for the frozen-LM macro reference baseline.
#
# Deploys base Qwen-7B-Instruct on macro_economics with NO SFT and NO KL
# anchor for the full n_rounds. Measures the population trajectory under
# the pretrained prior alone. Macro analog of at_covid_lm_baseline.sub.
#
# Submit with:  condor_submit_bid <BID> condor/at_macro_lm_baseline.sub

universe          = vanilla
executable        = /home/gsmithline/perfsim/condor/run_one_macro.sh
arguments         = $(tag) $(style) $(beta)

# ---- resources ----
# Only the trainee model is loaded (no KL reference), so memory is roughly
# half what the sft_kl runs need.
request_cpus      = 4
request_memory    = 64G
request_disk      = 40G
request_gpus      = 1
requirements      = (TARGET.CUDAGlobalMemoryMb >= 40000)

# ---- env / io ----
getenv            = False
environment       = "REPO=/home/gsmithline/perfsim CONDA_SH=/home/gsmithline/miniconda3/etc/profile.d/conda.sh ENV_NAME=opdyn WANDB_KEY_FILE=/home/gsmithline/.wandb_key WANDB_PROJECT=perfsim-at-macro-lm N_ROUNDS=5 K_STEPS=3 BASE_MODEL=Qwen/Qwen2.5-7B-Instruct SFT_MAX_STEPS=20 SFT_FULL_EPOCH=0 SFT_BATCH_SIZE=16 GEN_BATCH_SIZE=32 MACRO_YAML=config_100_agents.yaml SFT_SANITY=0 LORA_R=32 USE_LORA=1 SFT_LR=1e-5 WANDB_RUN_SUFFIX=_qwen7b_frozen_baseline"

output            = /home/gsmithline/perfsim/condor/logs/$(tag).out
error             = /home/gsmithline/perfsim/condor/logs/$(tag).err
log               = /home/gsmithline/perfsim/condor/logs/$(tag).log

# ---- email + retries ----
notification      = Complete
notify_user       = gabriel.smithline@tue.ellis.eu
max_retries       = 2
on_exit_hold      = (ExitCode =!= 0)

queue tag, style, beta from condor/configs_macro_baseline.txt
